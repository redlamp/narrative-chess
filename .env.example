# Supabase — public-safe values exposed to the client
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key — server-only. Used by /api/cron/timeout-sweep.
SUPABASE_SERVICE_ROLE_KEY=

# CRON secret — required by /api/cron/timeout-sweep. Vercel auto-injects in
# production cron triggers; set in Vercel project envs (Production + Preview-dev).
# Local: only needed if you intend to curl the endpoint manually.
CRON_SECRET=
